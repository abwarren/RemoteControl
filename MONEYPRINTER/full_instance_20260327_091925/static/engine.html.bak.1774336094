<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PLO Engine</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      color: #fff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Tab Bar Styles */
    .tab-bar-container {
      background: rgba(0, 0, 0, 0.5);
      padding: 0;
      border-radius: 0;
      margin-bottom: 0;
      border-bottom: 3px solid #00d4aa;
    }

    .tab-bar {
      display: flex;
      gap: 0;
      overflow-x: auto;
    }

    .tab {
      flex: 1;
      min-width: 120px;
      padding: 15px 20px;
      background: rgba(255, 255, 255, 0.05);
      border: none;
      color: #888;
      font-weight: 600;
      font-size: 0.9em;
      cursor: pointer;
      transition: all 0.3s;
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .tab:hover:not(.tab-active) {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
    }

    .tab.tab-active {
      background: linear-gradient(135deg, #00d4aa 0%, #00a896 100%);
      color: #000;
      font-weight: bold;
      box-shadow: 0 -3px 10px rgba(0, 212, 170, 0.3);
    }

    .tab.tab-unallocated {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .tab.tab-unallocated:hover {
      background: rgba(255, 255, 255, 0.05);
      color: #888;
    }

    /* Engine Layout */
    .engine-container {
      display: flex;
      flex: 1;
      height: calc(100vh - 54px);
    }

    .panel {
      display: flex;
      flex-direction: column;
      background: rgba(0, 0, 0, 0.4);
      border-right: 2px solid rgba(0, 212, 170, 0.3);
    }

    .panel:last-child {
      border-right: none;
    }

    .panel-header {
      background: rgba(0, 0, 0, 0.6);
      padding: 20px;
      border-bottom: 2px solid #00d4aa;
    }

    .panel-header h2 {
      font-size: 1.5em;
      color: #00d4aa;
      letter-spacing: 2px;
    }

    .panel-content {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
    }

    .left-panel {
      width: 20%;
      min-width: 280px;
    }

    .right-panel {
      width: 80%;
      flex: 1;
    }

    /* Collector Panel */
    .import-section {
      margin-bottom: 20px;
    }

    .import-section h3 {
      color: #00d4aa;
      margin-bottom: 10px;
      font-size: 1.1em;
    }

    .import-textarea {
      width: 100%;
      min-height: 150px;
      background: rgba(0, 0, 0, 0.5);
      border: 2px solid rgba(0, 212, 170, 0.3);
      border-radius: 8px;
      padding: 15px;
      color: #fff;
      font-family: 'Courier New', monospace;
      font-size: 0.9em;
      resize: vertical;
    }

    .import-textarea:focus {
      outline: none;
      border-color: #00d4aa;
    }

    .import-btn {
      background: #00d4aa;
      color: #000;
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
      margin-top: 10px;
    }

    .import-btn:hover {
      background: #00ffcc;
      transform: translateY(-2px);
    }

    .hand-list {
      margin-top: 20px;
    }

    .hand-item {
      background: rgba(255, 255, 255, 0.1);
      padding: 15px;
      margin-bottom: 15px;
      border-radius: 8px;
      border-left: 4px solid #666;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Courier New', monospace;
    }

    .hand-item:hover {
      background: rgba(255, 255, 255, 0.15);
      transform: translateX(5px);
    }

    .hand-item.selected {
      border-left-color: #00d4aa;
      background: rgba(0, 212, 170, 0.2);
    }

    .hand-item .hero-hand {
      color: #ffc107;
      font-size: 1.1em;
      font-weight: bold;
      margin-bottom: 5px;
    }

    .hand-item .board {
      color: #00d4aa;
      font-size: 0.9em;
    }

    .hand-item .variant-badge {
      display: inline-block;
      background: rgba(0, 212, 170, 0.3);
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 0.75em;
      margin-top: 8px;
      color: #00d4aa;
    }

    /* Engine Panel */
    .variant-selector {
      margin-bottom: 20px;
    }

    .variant-selector label {
      display: block;
      color: #00d4aa;
      margin-bottom: 8px;
      font-weight: 600;
    }

    .variant-selector select {
      width: 100%;
      padding: 12px;
      background: rgba(0, 0, 0, 0.5);
      border: 2px solid rgba(0, 212, 170, 0.3);
      border-radius: 8px;
      color: #fff;
      font-size: 1em;
      cursor: pointer;
    }

    .variant-selector select:focus {
      outline: none;
      border-color: #00d4aa;
    }

    .engine-textarea {
      width: 100%;
      min-height: 200px;
      background: rgba(0, 0, 0, 0.5);
      border: 2px solid rgba(0, 212, 170, 0.3);
      border-radius: 8px;
      padding: 15px;
      color: #fff;
      font-family: 'Courier New', monospace;
      font-size: 1em;
      resize: vertical;
      margin-bottom: 20px;
    }

    .engine-textarea:focus {
      outline: none;
      border-color: #00d4aa;
    }

    .engine-info {
      background: rgba(0, 212, 170, 0.1);
      padding: 15px;
      border-radius: 8px;
      border-left: 4px solid #00d4aa;
      margin-bottom: 20px;
    }

    .engine-info h3 {
      color: #00d4aa;
      margin-bottom: 10px;
    }

    .engine-info p {
      color: #ccc;
      line-height: 1.6;
      margin: 5px 0;
    }

    .engine-actions {
      display: flex;
      gap: 10px;
    }

    .engine-btn {
      flex: 1;
      padding: 15px;
      background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
      border: none;
      border-radius: 8px;
      color: #000;
      font-weight: bold;
      font-size: 1em;
      cursor: pointer;
      transition: all 0.2s;
    }

    .engine-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(255, 193, 7, 0.4);
    }

    .engine-btn.secondary {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
    }

    .engine-btn.secondary:hover {
      background: rgba(255, 255, 255, 0.2);
      box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
    }

    /* Placeholder Modal */
    .placeholder-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.9);
      z-index: 9999;
      justify-content: center;
      align-items: center;
    }

    .placeholder-modal.active {
      display: flex;
    }

    .placeholder-content {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      padding: 60px 80px;
      border-radius: 15px;
      border: 3px solid #00d4aa;
      text-align: center;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
    }

    .placeholder-content h2 {
      font-size: 2.5em;
      margin-bottom: 20px;
      color: #00d4aa;
    }

    .placeholder-content p {
      font-size: 1.2em;
      color: #fff;
      margin-bottom: 30px;
    }

    .placeholder-close {
      background: #f44336;
      color: white;
      padding: 12px 30px;
      border: none;
      border-radius: 8px;
      font-size: 1em;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
    }

    .placeholder-close:hover {
      background: #d32f2f;
      transform: translateY(-2px);
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .engine-container {
        flex-direction: column;
      }
      
      .left-panel, .right-panel {
        width: 100%;
        min-width: 100%;
      }
      
      .left-panel {
        max-height: 400px;
      }
    }
  </style>
</head>
<body>
  <!-- Tab Bar -->
  <div class="tab-bar-container">
    <div class="tab-bar">
      <button class="tab" onclick="handleTabClick('RemoteControl')" id="tab-RemoteControl">Remote Control</button>
      <button class="tab tab-active" onclick="handleTabClick('Engine')" id="tab-Engine">Engine</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab3')" id="tab-Tab3">Tab 3</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab4')" id="tab-Tab4">Tab 4</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab5')" id="tab-Tab5">Tab 5</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab6')" id="tab-Tab6">Tab 6</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab7')" id="tab-Tab7">Tab 7</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab8')" id="tab-Tab8">Tab 8</button>
    </div>
  </div>

  <!-- Placeholder Modal -->
  <div class="placeholder-modal" id="placeholderModal">
    <div class="placeholder-content">
      <h2 id="placeholderTitle">Feature Coming Soon</h2>
      <p>This tab is currently unallocated.</p>
      <button class="placeholder-close" onclick="closePlaceholder()">Close</button>
    </div>
  </div>

  <!-- Engine Layout -->
  <div class="engine-container">
    <!-- Left Panel: Collector (20%) -->
    <div class="panel left-panel">
      <div class="panel-header">
        <h2>COLLECTOR</h2>
      </div>
      <div class="panel-content">
        <div class="import-section">
          <h3>Import API Text</h3>
          <textarea 
            id="importTextarea" 
            class="import-textarea" 
            placeholder="Paste hand data here...&#10;&#10;Example format:&#10;AsKdQcJh&#10;9sTd2c&#10;&#10;Each hand should have:&#10;- Hero hand (8-14 chars)&#10;- Board (optional)"
          ></textarea>
          <button class="import-btn" onclick="importHands()">Parse Hands</button>
        </div>
        
        <div class="hand-list" id="handList">
          <!-- Hands will be populated here -->
        </div>
      </div>
    </div>

    <!-- Right Panel: ENGINE (80%) -->
    <div class="panel right-panel">
      <div class="panel-header">
        <h2>ENGINE</h2>
      </div>
      <div class="panel-content">
        <div class="variant-selector">
          <label for="variantSelect">Game Variant:</label>
          <select id="variantSelect" onchange="updateEngineInput()">
            <option value="">-- Select Variant --</option>
            <option value="PLO4-6MAX">PLO4-6MAX (6 players, 4 hole cards)</option>
            <option value="PLO4-8MAX">PLO4-8MAX (8 players, 4 hole cards)</option>
            <option value="PLO4-9MAX">PLO4-9MAX (9 players, 4 hole cards)</option>
            <option value="PLO5-6MAX">PLO5-6MAX (6 players, 5 hole cards)</option>
            <option value="PLO5-5MAX">PLO5-5MAX (5 players, 5 hole cards)</option>
            <option value="PLO6-5MAX">PLO6-5MAX (5 players, 6 hole cards)</option>
            <option value="PLO6-6MAX">PLO6-6MAX (6 players, 6 hole cards)</option>
          </select>
        </div>

        <div class="engine-info" id="engineInfo">
          <h3>Engine Input</h3>
          <p id="infoVariant">Variant: <em>Not selected</em></p>
          <p id="infoHero">Hero Hand: <em>Not selected</em></p>
          <p id="infoBoard">Board: <em>Not selected</em></p>
          <p id="infoConfig">Config: <em>-</em></p>
        </div>

        <textarea 
          id="engineTextarea" 
          class="engine-textarea" 
          placeholder="Select a hand from the Collector panel..."
          readonly
        ></textarea>

        <div class="engine-actions">
          <button class="engine-btn" onclick="runEngine()">Calculate Equity</button>
          <button class="engine-btn secondary" onclick="clearEngine()">Clear</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const CURRENT_PAGE = 'Engine';
    const REMOTE_CONTROL_URL = 'https://test.potlimitomaha.xyz:8080';

    // Game constraints
    const MIN_PLAYERS = 5;
    const MAX_PLAYERS = 9;
    const MIN_HOLE_CARDS = 4;
    const MAX_HOLE_CARDS = 7;

    // Variant configuration
    const VARIANT_CONFIG = {
      'PLO4-6MAX': {players: 6, hole_cards: 4},
      'PLO4-8MAX': {players: 8, hole_cards: 4},
      'PLO4-9MAX': {players: 9, hole_cards: 4},
      'PLO5-6MAX': {players: 6, hole_cards: 5},
      'PLO5-5MAX': {players: 5, hole_cards: 5},
      'PLO6-5MAX': {players: 5, hole_cards: 6},
      'PLO6-6MAX': {players: 6, hole_cards: 6}
    };

    // State
    let parsedHands = [];
    let selectedHandIndex = null;

    function handleTabClick(tabName) {
      if (tabName === 'RemoteControl') {
        window.location.href = REMOTE_CONTROL_URL;
      } else if (tabName === 'Engine') {
        return;
      } else {
        showPlaceholder(tabName);
      }
    }

    function showPlaceholder(tabName) {
      const modal = document.getElementById('placeholderModal');
      const title = document.getElementById('placeholderTitle');
      title.textContent = tabName + ' - Coming Soon';
      modal.classList.add('active');
    }

    function closePlaceholder() {
      const modal = document.getElementById('placeholderModal');
      modal.classList.remove('active');
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closePlaceholder();
      }
    });

    function isValidVariant(variant) {
      if (!(variant in VARIANT_CONFIG)) return false;
      const cfg = VARIANT_CONFIG[variant];
      return (
        cfg.players >= MIN_PLAYERS &&
        cfg.players <= MAX_PLAYERS &&
        cfg.hole_cards >= MIN_HOLE_CARDS &&
        cfg.hole_cards <= MAX_HOLE_CARDS
      );
    }

    function parseVariant(variant) {
      if (!isValidVariant(variant)) {
        throw new Error('Invalid variant');
      }
      return VARIANT_CONFIG[variant];
    }

    function detectVariant(heroHand) {
      const handLength = heroHand.replace(/\s/g, '').length;
      const holeCards = handLength / 2;
      
      // Default to 6MAX for most variants
      if (holeCards === 4) return 'PLO4-6MAX';
      if (holeCards === 5) return 'PLO5-6MAX';
      if (holeCards === 6) return 'PLO6-6MAX';
      if (holeCards === 7) return null; // PLO7 not in list
      
      return null;
    }

    function importHands() {
      const textarea = document.getElementById('importTextarea');
      const text = textarea.value.trim();
      
      if (!text) {
        alert('Please paste hand data first');
        return;
      }

      parsedHands = [];
      const lines = text.split('\n').map(l => l.trim()).filter(l => l);
      
      let i = 0;
      while (i < lines.length) {
        const line = lines[i];
        
        // Check if this line is a valid hero hand (8-14 chars, ASCII cards)
        const cleanLine = line.replace(/\s/g, '');
        if (cleanLine.length >= 8 && cleanLine.length <= 14 && /^[AKQJT2-9][shdc]+$//i.test(cleanLine)) {
          const heroHand = cleanLine;
          const board = (i + 1 < lines.length) ? lines[i + 1] : '';
          const variant = detectVariant(heroHand);
          
          parsedHands.push({
            hero: heroHand,
            board: board,
            variant: variant
          });
          
          i += 2; // Skip hero + board
        } else {
          i++;
        }
      }

      renderHandList();
      console.log('Parsed', parsedHands.length, 'hands');
    }

    function renderHandList() {
      const container = document.getElementById('handList');
      
      if (parsedHands.length === 0) {
        container.innerHTML = '<p style="color:#888;text-align:center;padding:20px;">No hands parsed yet</p>';
        return;
      }

      container.innerHTML = parsedHands.map((hand, idx) => `
        <div class="hand-item ${selectedHandIndex === idx ? 'selected' : ''}" onclick="selectHand(${idx})">
          <div class="hero-hand">${hand.hero}</div>
          <div class="board">${hand.board || '(no board)'}</div>
          ${hand.variant ? `<div class="variant-badge">${hand.variant}</div>` : ''}
        </div>
      `).join('');
    }

    function selectHand(index) {
      selectedHandIndex = index;
      renderHandList();
      updateEngineInput();
    }

    function updateEngineInput() {
      if (selectedHandIndex === null || selectedHandIndex >= parsedHands.length) {
        return;
      }

      const hand = parsedHands[selectedHandIndex];
      const variant = document.getElementById('variantSelect').value || hand.variant;
      
      // Update engine textarea
      const engineTextarea = document.getElementById('engineTextarea');
      engineTextarea.value = `Hero Hand: ${hand.hero}\nBoard: ${hand.board || 'none'}\nVariant: ${variant || 'auto'}`;

      // Update info panel
      document.getElementById('infoVariant').innerHTML = `Variant: <strong>${variant || 'Not selected'}</strong>`;
      document.getElementById('infoHero').innerHTML = `Hero Hand: <strong>${hand.hero}</strong>`;
      document.getElementById('infoBoard').innerHTML = `Board: <strong>${hand.board || 'none'}</strong>`;

      if (variant && isValidVariant(variant)) {
        const config = parseVariant(variant);
        document.getElementById('infoConfig').innerHTML = `Config: <strong>${config.players} players, ${config.hole_cards} hole cards</strong>`;
      } else {
        document.getElementById('infoConfig').innerHTML = 'Config: <em>Invalid or not selected</em>';
      }
    }

    function runEngine() {
      if (selectedHandIndex === null) {
        alert('Please select a hand from the Collector first');
        return;
      }

      const variant = document.getElementById('variantSelect').value;
      if (!variant || !isValidVariant(variant)) {
        alert('Please select a valid variant');
        return;
      }

      const hand = parsedHands[selectedHandIndex];
      const engineTextarea = document.getElementById('engineTextarea');
      
      // Show calculating message
      engineTextarea.value = 'Calculating equity...\n\nThis may take a few seconds.';

      // Call equity API
      fetch('/api/equity/calculate', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          variant: variant,
          hero_hand: hand.hero,
          board: hand.board || '',
          villain_hands: []  // Will use random opponent
        })
      })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          // Display results in textarea
          engineTextarea.value = data.output;
          console.log('Equity calculation complete:', data);
        } else {
          engineTextarea.value = 'Error: ' + (data.error || 'Unknown error') + '\n\n' + (data.stderr || '');
          console.error('Equity calculation failed:', data);
        }
      })
      .catch(err => {
        engineTextarea.value = 'Network error: ' + err.message;
        console.error('Equity API error:', err);
      });
    }

    function clearEngine() {
      document.getElementById('engineTextarea').value = '';
      document.getElementById('variantSelect').value = '';
      selectedHandIndex = null;
      renderHandList();
      
      document.getElementById('infoVariant').innerHTML = 'Variant: <em>Not selected</em>';
      document.getElementById('infoHero').innerHTML = 'Hero Hand: <em>Not selected</em>';
      document.getElementById('infoBoard').innerHTML = 'Board: <em>Not selected</em>';
      document.getElementById('infoConfig').innerHTML = 'Config: <em>-</em>';
    }

    // Load hands from collector API on page load
    window.addEventListener('DOMContentLoaded', function() {
      loadCollectorHands();
    });

    function loadCollectorHands() {
      fetch('/api/collector/latest')
        .then(r => r.json())
        .then(data => {
          if (data.ok && data.raw) {
            document.getElementById('importTextarea').value = data.raw;
            console.log('Loaded hand from API:', data);
          }
        })
        .catch(err => console.error('Collector fetch error:', err));
    }
  </script>
</body>
</html>
