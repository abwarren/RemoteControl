<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PLO Engine</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      color: #fff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Tab Bar Styles */
    .tab-bar-container {
      background: rgba(0, 0, 0, 0.5);
      padding: 0;
      border-radius: 0;
      margin-bottom: 0;
      border-bottom: 3px solid #00d4aa;
    }

    .tab-bar {
      display: flex;
      gap: 0;
      overflow-x: auto;
    }

    .tab {
      flex: 1;
      min-width: 120px;
      padding: 15px 20px;
      background: rgba(255, 255, 255, 0.05);
      border: none;
      color: #888;
      font-weight: 600;
      font-size: 0.9em;
      cursor: pointer;
      transition: all 0.3s;
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .tab:hover:not(.tab-active) {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
    }

    .tab.tab-active {
      background: linear-gradient(135deg, #00d4aa 0%, #00a896 100%);
      color: #000;
      font-weight: bold;
      box-shadow: 0 -3px 10px rgba(0, 212, 170, 0.3);
    }

    .tab.tab-unallocated {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .tab.tab-unallocated:hover {
      background: rgba(255, 255, 255, 0.05);
      color: #888;
    }

    /* Engine Layout */
    .engine-container {
      display: flex;
      flex: 1;
      height: calc(100vh - 54px);
    }

    .panel {
      display: flex;
      flex-direction: column;
      background: rgba(0, 0, 0, 0.4);
      border-right: 2px solid rgba(0, 212, 170, 0.3);
    }

    .panel:last-child {
      border-right: none;
    }

    .panel-header {
      background: rgba(0, 0, 0, 0.6);
      padding: 20px;
      border-bottom: 2px solid #00d4aa;
    }

    .panel-header h2 {
      font-size: 1.5em;
      color: #00d4aa;
      letter-spacing: 2px;
    }

    .panel-content {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
    }

    .left-panel {
      width: 20%;
      min-width: 250px;
    }

    .right-panel {
      width: 80%;
      flex: 1;
    }

    /* Collector Panel */
    .collector-item {
      background: rgba(255, 255, 255, 0.1);
      padding: 15px;
      margin-bottom: 15px;
      border-radius: 8px;
      border-left: 4px solid #00d4aa;
      cursor: pointer;
      transition: all 0.2s;
    }

    .collector-item:hover {
      background: rgba(255, 255, 255, 0.15);
      transform: translateX(5px);
    }

    .collector-item h4 {
      color: #00d4aa;
      margin-bottom: 8px;
    }

    .collector-item p {
      font-size: 0.9em;
      color: #ccc;
    }

    /* Engine Panel */
    .engine-display {
      background: rgba(0, 0, 0, 0.3);
      padding: 30px;
      border-radius: 10px;
      min-height: 400px;
    }

    .engine-title {
      font-size: 2em;
      color: #ffc107;
      margin-bottom: 20px;
      text-align: center;
    }

    .engine-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
    }

    .engine-card {
      background: rgba(255, 255, 255, 0.1);
      padding: 25px;
      border-radius: 10px;
      border: 2px solid rgba(0, 212, 170, 0.3);
    }

    .engine-card h3 {
      color: #00d4aa;
      margin-bottom: 15px;
      font-size: 1.3em;
    }

    .engine-card p {
      line-height: 1.6;
      color: #ddd;
    }

    /* Placeholder Modal */
    .placeholder-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.9);
      z-index: 9999;
      justify-content: center;
      align-items: center;
    }

    .placeholder-modal.active {
      display: flex;
    }

    .placeholder-content {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      padding: 60px 80px;
      border-radius: 15px;
      border: 3px solid #00d4aa;
      text-align: center;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
    }

    .placeholder-content h2 {
      font-size: 2.5em;
      margin-bottom: 20px;
      color: #00d4aa;
    }

    .placeholder-content p {
      font-size: 1.2em;
      color: #fff;
      margin-bottom: 30px;
    }

    .placeholder-close {
      background: #f44336;
      color: white;
      padding: 12px 30px;
      border: none;
      border-radius: 8px;
      font-size: 1em;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
    }

    .placeholder-close:hover {
      background: #d32f2f;
      transform: translateY(-2px);
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .engine-container {
        flex-direction: column;
      }
      
      .left-panel, .right-panel {
        width: 100%;
        min-width: 100%;
      }
      
      .left-panel {
        max-height: 300px;
      }
    }
  </style>
</head>
<body>
  <!-- Tab Bar -->
  <div class="tab-bar-container">
    <div class="tab-bar">
      <button class="tab" onclick="handleTabClick('RemoteControl')" id="tab-RemoteControl">Remote Control</button>
      <button class="tab tab-active" onclick="handleTabClick('Engine')" id="tab-Engine">Engine</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab3')" id="tab-Tab3">Tab 3</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab4')" id="tab-Tab4">Tab 4</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab5')" id="tab-Tab5">Tab 5</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab6')" id="tab-Tab6">Tab 6</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab7')" id="tab-Tab7">Tab 7</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab8')" id="tab-Tab8">Tab 8</button>
    </div>
  </div>

  <!-- Placeholder Modal -->
  <div class="placeholder-modal" id="placeholderModal">
    <div class="placeholder-content">
      <h2 id="placeholderTitle">Feature Coming Soon</h2>
      <p>This tab is currently unallocated.</p>
      <button class="placeholder-close" onclick="closePlaceholder()">Close</button>
    </div>
  </div>

  <!-- Engine Layout -->
  <div class="engine-container">
    <!-- Left Panel: Collector (20%) -->
    <div class="panel left-panel">
      <div class="panel-header">
        <h2>COLLECTOR</h2>
      </div>
      <div class="panel-content" id="collectorPanel">
        <div class="collector-item">
          <h4>Recent Hand #1</h4>
          <p>PLO5 - 6max</p>
          <p>Board: K♠ Q♥ 7♦ 3♣ A♠</p>
        </div>
        <div class="collector-item">
          <h4>Recent Hand #2</h4>
          <p>PLO5 - 6max</p>
          <p>Board: 9♠ 8♥ 7♦ 6♣ 5♠</p>
        </div>
        <div class="collector-item">
          <h4>Recent Hand #3</h4>
          <p>PLO5 - 6max</p>
          <p>Board: A♠ A♥ K♦ Q♣ J♠</p>
        </div>
      </div>
    </div>

    <!-- Right Panel: ENGINE (80%) -->
    <div class="panel right-panel">
      <div class="panel-header">
        <h2>ENGINE</h2>
      </div>
      <div class="panel-content">
        <div class="engine-display">
          <div class="engine-title">PLO EQUITY ENGINE</div>
          <div class="engine-content">
            <div class="engine-card">
              <h3>Hand Analysis</h3>
              <p>Advanced equity calculations for PLO5 hands. Calculate exact equity against opponent ranges.</p>
            </div>
            <div class="engine-card">
              <h3>Range Builder</h3>
              <p>Build and save custom opponent ranges. Analyze vs specific hand combinations.</p>
            </div>
            <div class="engine-card">
              <h3>Simulator</h3>
              <p>Run Monte Carlo simulations with millions of trials. Get precise equity percentages.</p>
            </div>
            <div class="engine-card">
              <h3>Database</h3>
              <p>Store and retrieve hand histories. Build your personal database of analyzed hands.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const CURRENT_PAGE = 'Engine';
    const REMOTE_CONTROL_URL = 'https://test.potlimitomaha.xyz:8080';

    function handleTabClick(tabName) {
      if (tabName === 'RemoteControl') {
        // Navigate back to Remote Control
        window.location.href = REMOTE_CONTROL_URL;
      } else if (tabName === 'Engine') {
        // Already on Engine page, do nothing
        return;
      } else {
        // Show placeholder for unallocated tabs
        showPlaceholder(tabName);
      }
    }

    function showPlaceholder(tabName) {
      const modal = document.getElementById('placeholderModal');
      const title = document.getElementById('placeholderTitle');
      title.textContent = tabName + ' - Coming Soon';
      modal.classList.add('active');
    }

    function closePlaceholder() {
      const modal = document.getElementById('placeholderModal');
      modal.classList.remove('active');
    }

    // Close modal on ESC key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closePlaceholder();
      }
    });

    // Load hands from collector API
    function loadCollectorHands() {
      fetch('/api/collector/latest')
        .then(r => r.json())
        .then(data => {
          if (data.ok) {
            console.log('Latest hand:', data);
            // Update collector panel with real data
          }
        })
        .catch(err => console.error('Collector fetch error:', err));
    }

    // Load on page load
    window.addEventListener('DOMContentLoaded', function() {
      loadCollectorHands();
    });
  </script>
</body>
</html>
