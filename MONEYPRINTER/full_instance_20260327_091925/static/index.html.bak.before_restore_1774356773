<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>N4P Remote Table Control</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      color: #fff;
      min-height: 100vh;
      padding: 20px;
    }

    .header {
      background: rgba(0, 0, 0, 0.3);
      padding: 20px;
      border-radius: 10px;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header h1 {
      font-size: 2em;
      letter-spacing: 2px;
    }

    .test-badge {
      background: #ff6b35;
      padding: 8px 16px;
      border-radius: 5px;
      font-weight: bold;
      font-size: 0.9em;
    }

    .table-container {
      background: rgba(0, 0, 0, 0.4);
      padding: 30px;
      border-radius: 10px;
      margin-bottom: 20px;
    }

    .table-info {
      text-align: center;
      margin-bottom: 20px;
    }

    .board-display {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
      padding: 20px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 10px;
    }

    .card-img {
      height: 80px;
      width: auto;
      border-radius: 8px;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.4);
      transition: transform 0.2s;
    }

    .card-img:hover {
      transform: scale(1.1);
    }

    .seats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    @media (max-width: 1200px) {
      .seats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .seats-grid {
        grid-template-columns: 1fr;
      }
    }

    .seat-card {
      background: rgba(255, 255, 255, 0.15);
      border-radius: 8px;
      padding: 12px;
      border: 3px solid transparent;
      transition: all 0.3s;
    }

    .seat-card.connected {
      border-color: #4caf50;
    }

    .seat-card.empty {
      opacity: 0.5;
    }

    .seat-card.action-on {
      border-color: #ffc107;
      animation: blink-border 1s infinite;
    }

    @keyframes blink-border {
      0%, 100% {
        border-color: #ffc107;
        box-shadow: 0 0 20px #ffc107;
      }
      50% {
        border-color: #ff5722;
        box-shadow: 0 0 40px #ff5722;
      }
    }

    .seat-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
      padding-bottom: 6px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    }

    .seat-title {
      font-size: 0.95em;
      font-weight: bold;
    }

    .status-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-left: 6px;
    }

    .status-dot.live {
      background: #4caf50;
      box-shadow: 0 0 8px #4caf50;
    }

    .status-dot.offline {
      background: #666;
    }

    .dealer-marker {
      background: #ffc107;
      color: #000;
      padding: 2px 6px;
      border-radius: 3px;
      font-size: 0.7em;
      font-weight: bold;
    }

    .seat-info {
      margin-bottom: 8px;
      font-size: 0.85em;
    }

    .pre-actions {
      margin: 6px 0;
      padding: 6px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
    }

    .pre-action-item {
      display: flex;
      align-items: center;
      margin: 3px 0;
    }

    .pre-action-item input[type="checkbox"] {
      width: 14px;
      height: 14px;
      margin-right: 6px;
      cursor: pointer;
    }

    .pre-action-item label {
      cursor: pointer;
      font-size: 0.75em;
    }

    .seat-info div {
      margin: 3px 0;
    }

    .hole-cards {
      display: flex;
      gap: 4px;
      margin-top: 6px;
    }

    .hole-card-img {
      height: 50px;
      width: auto;
      border-radius: 4px;
      box-shadow: 0 3px 6px rgba(0, 0, 0, 0.4);
      transition: transform 0.2s;
    }

    .hole-card-img:hover {
      transform: scale(1.15);
    }

    .action-buttons {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 5px;
      margin-top: 8px;
    }

    .action-btn {
      padding: 6px 4px;
      border: none;
      border-radius: 4px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 0.7em;
    }

    .action-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 3px 6px rgba(0, 0, 0, 0.3);
    }

    .action-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .btn-fold {
      background: #f44336;
      color: white;
    }

    .btn-check {
      background: #4caf50;
      color: white;
    }

    .btn-call {
      background: #2196f3;
      color: white;
    }

    .btn-raise-pot {
      background: #9c27b0;
      color: white;
      font-weight: bold;
    }

    .btn-raise {
      background: #ff5722;
      color: white;
      font-weight: bold;
    }

    .btn-cashout {
      background: #ffc107;
      color: #000;
      font-weight: bold;
    }

    .btn-check-fold {
      background: #ff9800;
      color: white;
      grid-column: span 2;
    }

    .btn-check-call {
      background: #9c27b0;
      color: white;
      grid-column: span 2;
    }

    .btn-clear {
      background: #666;
      color: white;
      grid-column: span 3;
    }

    .pending-badge {
      background: #ff6b35;
      color: white;
      padding: 4px 8px;
      border-radius: 3px;
      font-size: 0.8em;
      display: inline-block;
      margin-top: 10px;
    }

    .command-log {
      background: rgba(0, 0, 0, 0.4);
      padding: 20px;
      border-radius: 10px;
      max-height: 300px;
      overflow-y: auto;
    }

    .command-log h3 {
      margin-bottom: 15px;
    }

    .log-entry {
      padding: 8px;
      margin: 5px 0;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 5px;
      font-size: 0.9em;
      display: flex;
      justify-content: space-between;
    }

    .waiting-message {
      text-align: center;
      padding: 60px 20px;
      font-size: 1.5em;
      opacity: 0.7;
    }

    .pot-display {
      font-size: 1.5em;
      font-weight: bold;
      color: #ffc107;
    }

    .street-display {
      background: rgba(255, 255, 255, 0.2);
      padding: 8px 16px;
      border-radius: 5px;
      display: inline-block;
    }

    .inject-box {
      background: rgba(0, 0, 0, 0.5);
      padding: 15px 20px;
      border-radius: 10px;
      margin-bottom: 20px;
      border: 2px solid #00d4aa;
    }

    .inject-box h3 {
      margin-bottom: 10px;
      color: #00d4aa;
      font-size: 1.1em;
    }

    .inject-code {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .code-display {
      flex: 1;
      background: #000;
      padding: 12px 15px;
      border-radius: 5px;
      font-family: 'Courier New', monospace;
      font-size: 0.85em;
      color: #00ff00;
      overflow-x: auto;
      white-space: nowrap;
    }

    .copy-btn {
      background: #00d4aa;
      color: #000;
      border: none;
      padding: 12px 24px;
      border-radius: 5px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .copy-btn:hover {
      background: #00ffcc;
      transform: translateY(-2px);
      box-shadow: 0 4px 8px rgba(0, 212, 170, 0.4);
    }

    .copy-btn.copied {
      background: #4caf50;
      color: white;
    }

    /* Tab Bar Styles */
    .tab-bar-container {
      background: rgba(0, 0, 0, 0.5);
      padding: 0;
      border-radius: 10px 10px 0 0;
      margin-bottom: 0;
      border-bottom: 3px solid #00d4aa;
    }

    .tab-bar {
      display: flex;
      gap: 0;
      overflow-x: auto;
    }

    .tab {
      flex: 1;
      min-width: 120px;
      padding: 15px 20px;
      background: rgba(255, 255, 255, 0.05);
      border: none;
      color: #888;
      font-weight: 600;
      font-size: 0.9em;
      cursor: pointer;
      transition: all 0.3s;
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .tab:first-child {
      border-radius: 10px 0 0 0;
    }

    .tab:last-child {
      border-right: none;
      border-radius: 0 10px 0 0;
    }

    .tab:hover:not(.tab-active) {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
    }

    .tab.tab-active {
      background: linear-gradient(135deg, #00d4aa 0%, #00a896 100%);
      color: #000;
      font-weight: bold;
      box-shadow: 0 -3px 10px rgba(0, 212, 170, 0.3);
    }

    .tab.tab-unallocated {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .tab.tab-unallocated:hover {
      background: rgba(255, 255, 255, 0.05);
      color: #888;
    }

    /* Placeholder Modal */
    .placeholder-modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.9);
      z-index: 9999;
      justify-content: center;
      align-items: center;
    }

    .placeholder-modal.active {
      display: flex;
    }

    .placeholder-content {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      padding: 60px 80px;
      border-radius: 15px;
      border: 3px solid #00d4aa;
      text-align: center;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
    }

    .placeholder-content h2 {
      font-size: 2.5em;
      margin-bottom: 20px;
      color: #00d4aa;
    }

    .placeholder-content p {
      font-size: 1.2em;
      color: #fff;
      margin-bottom: 30px;
    }

    .placeholder-close {
      background: #f44336;
      color: white;
      padding: 12px 30px;
      border: none;
      border-radius: 8px;
      font-size: 1em;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
    }

    .placeholder-close:hover {
      background: #d32f2f;
      transform: translateY(-2px);
    }
  </style>
</head>
<body>
  <!-- Tab Bar -->
  <div class="tab-bar-container">
    <div class="tab-bar">
      <button class="tab" onclick="handleTabClick('RemoteControl')" id="tab-RemoteControl">Remote Control</button>
      <button class="tab" onclick="handleTabClick('Engine')" id="tab-Engine">Engine</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab3')" id="tab-Tab3">Tab 3</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab4')" id="tab-Tab4">Tab 4</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab5')" id="tab-Tab5">Tab 5</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab6')" id="tab-Tab6">Tab 6</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab7')" id="tab-Tab7">Tab 7</button>
      <button class="tab tab-unallocated" onclick="handleTabClick('Tab8')" id="tab-Tab8">Tab 8</button>
    </div>
  </div>

  <!-- Placeholder Modal -->
  <div class="placeholder-modal" id="placeholderModal">
    <div class="placeholder-content">
      <h2 id="placeholderTitle">Feature Coming Soon</h2>
      <p>This tab is currently unallocated.</p>
      <button class="placeholder-close" onclick="closePlaceholder()">Close</button>
    </div>
  </div>


  <div class="header">
    <div>
      <h1>N4P // REMOTE TABLE CONTROL</h1>
    </div>


  <div class="inject-box">
    <h3>📡 Inject Script into Poker Client</h3>
    <div class="inject-code">
      <div class="code-display" id="inject-command">fetch('https://test.potlimitomaha.xyz:8080/n4p.js').then(r=>r.text()).then(eval)</div>
      <button class="copy-btn" onclick="copyInjectCode()">COPY</button>
    </div>
  </div>
    <div class="test-badge">TEST</div>
  </div>

  <div id="app"></div>

  <div class="command-log">
    <h3>Command Log</h3>
    <div id="log-container"></div>
  </div>

  <script>
    // Tab Management
    const CURRENT_PAGE = 'RemoteControl';
    const ENGINE_URL = 'https://engine.potlimitomaha.xyz:8080';

    // Set active tab on load
    window.addEventListener('DOMContentLoaded', function() {
      setActiveTab('RemoteControl');
    });

    function setActiveTab(tabName) {
      // Remove active class from all tabs
      document.querySelectorAll('.tab').forEach(tab => {
        tab.classList.remove('tab-active');
      });
      
      // Add active class to current tab
      const activeTab = document.getElementById('tab-' + tabName);
      if (activeTab) {
        activeTab.classList.add('tab-active');
      }
    }

    function handleTabClick(tabName) {
      if (tabName === 'Engine') {
        // Navigate to Engine page
        window.location.href = ENGINE_URL;
      } else if (tabName === 'RemoteControl') {
        // Already on RemoteControl page, just highlight
        setActiveTab('RemoteControl');
      } else {
        // Show placeholder for unallocated tabs
        showPlaceholder(tabName);
      }
    }

    function showPlaceholder(tabName) {
      const modal = document.getElementById('placeholderModal');
      const title = document.getElementById('placeholderTitle');
      title.textContent = tabName + ' - Coming Soon';
      modal.classList.add('active');
    }

    function closePlaceholder() {
      const modal = document.getElementById('placeholderModal');
      modal.classList.remove('active');
    }

    // Close modal on ESC key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closePlaceholder();
      }
    });

    const API_BASE = '/api';
    let commandLog = [];

    // Format card as image
    function formatCard(card) {
      if (!card) return '';
      const suit = card.slice(-1).toLowerCase();
      const rank = card.slice(0, -1).toUpperCase();
      const cardImg = `${rank}${suit}.png`;
      return `<img src="/static/cards/${cardImg}" class="card-img" alt="${rank}${suit}" />`;
    }

    // Format hole card as image
    function formatHoleCard(card) {
      if (!card) return '';
      const suit = card.slice(-1).toLowerCase();
      const rank = card.slice(0, -1).toUpperCase();
      const cardImg = `${rank}${suit}.png`;
      return `<img src="/static/cards/${cardImg}" class="hole-card-img" alt="${rank}${suit}" />`;
    }

    // Toggle pre-action checkboxes
    function togglePreAction(tableId, seatIndex, action, checked) {
      if (checked) {
        // Uncheck the other checkbox
        const otherId = action === 'check_fold' ? 'cc-' + seatIndex : 'cf-' + seatIndex;
        const otherCheckbox = document.getElementById(otherId);
        if (otherCheckbox) otherCheckbox.checked = false;

        // Send the pre-action command
        sendCommand(tableId, seatIndex, action);
      } else {
        // Clear pre-action
        sendCommand(tableId, seatIndex, 'clear_preaction');
      }
    }

    // Send command
    function sendCommand(tableId, seatIndex, commandType) {
      fetch(API_BASE + '/commands/queue', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          table_id: tableId,
          seat_index: seatIndex,
          command_type: commandType
        })
      })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          addToLog(seatIndex, commandType, 'PENDING');
        } else {
          console.error('Command failed:', data.error);
        }
      })
      .catch(err => {
        console.error('Network error:', err);
      });
    }

    // Add to command log
    function addToLog(seatIndex, command, status) {
      const timestamp = new Date().toLocaleTimeString();
      commandLog.unshift({
        timestamp,
        seat: seatIndex,
        command,
        status
      });
      commandLog = commandLog.slice(0, 20); // Keep last 20
      updateLog();
    }

    // Update log display
    function updateLog() {
      const container = document.getElementById('log-container');
      container.innerHTML = commandLog.map(entry => `
        <div class="log-entry">
          <span>${entry.timestamp} | Seat ${entry.seat} | ${entry.command}</span>
          <span>${entry.status}</span>
        </div>
      `).join('');
    }

    // Render table
    function renderTable(table) {
      const app = document.getElementById('app');

      const board = table.board;
      const boardCards = [
        ...board.flop,
        board.turn,
        board.river
      ].filter(c => c);

      const boardHtml = boardCards.length > 0
        ? boardCards.map(formatCard).join('')
        : '<span style="opacity: 0.5;">Waiting for flop...</span>';

      const seatsHtml = table.seats.map(seat => {
        const isConnected = seat.has_token;
        const isActive = seat.status === 'playing';
        const canAct = isConnected && isActive;

        const holeCardsHtml = seat.hole_cards && seat.hole_cards.length > 0
          ? `<div class="hole-cards">${seat.hole_cards.map(formatHoleCard).join('')}</div>`
          : '';

        const liveClass = seat.name ? 'live' : 'offline';  // Green when player seated
        const cardClass = isConnected ? 'connected' : (seat.status === 'empty' ? 'empty' : '');
        const actionOn = seat.action_on || false;
        const actionClass = actionOn ? 'action-on' : '';

        const pendingHtml = seat.pending_cmd
          ? `<div class="pending-badge">⏳ ${seat.pending_cmd}</div>`
          : '';

        return `
          <div class="seat-card ${cardClass} ${actionClass}">
            <div class="seat-header">
              <div>
                <span class="seat-title">SEAT ${seat.seat_index}</span>
                <span class="status-dot ${liveClass}"></span>
              </div>
              ${seat.is_dealer ? '<span class="dealer-marker">DEALER</span>' : ''}
            </div>
            <div class="seat-info">
              <div><strong>${seat.name || 'Player ' + seat.seat_index}</strong></div>
              <div>ZAR ${seat.stack_zar ? seat.stack_zar.toFixed(2) : '0.00'}</div>
              <div>Status: ${seat.status.toUpperCase()}</div>
              ${holeCardsHtml}
              ${pendingHtml}
            </div>
            <div class="pre-actions">
              <div class="pre-action-item">
                <input type="checkbox" id="cf-${seat.seat_index}"
                   onchange="togglePreAction('${table.table_id}', ${seat.seat_index}, 'check_fold', this.checked)"
                   ${!canAct ? 'disabled' : ''}>
                <label for="cf-${seat.seat_index}">Check/Fold</label>
              </div>
              <div class="pre-action-item">
                <input type="checkbox" id="cc-${seat.seat_index}"
                   onchange="togglePreAction('${table.table_id}', ${seat.seat_index}, 'check_call', this.checked)"
                   ${!canAct ? 'disabled' : ''}>
                <label for="cc-${seat.seat_index}">Check/Call</label>
              </div>
            </div>
            <div class="action-buttons">
              <button class="action-btn btn-fold" ${!canAct ? 'disabled' : ''}
                onclick="sendCommand('${table.table_id}', ${seat.seat_index}, 'fold')">
                FOLD
              </button>
              <button class="action-btn btn-check" ${!canAct ? 'disabled' : ''}
                onclick="sendCommand('${table.table_id}', ${seat.seat_index}, 'check')">
                CHECK
              </button>
              <button class="action-btn btn-call" ${!canAct ? 'disabled' : ''}
                onclick="sendCommand('${table.table_id}', ${seat.seat_index}, 'call')">
                CALL
              </button>
              <button class="action-btn btn-raise-pot" ${!canAct ? 'disabled' : ''}
                onclick="sendCommand('${table.table_id}', ${seat.seat_index}, 'raise_pot')">
                RAISE POT
              </button>
              <button class="action-btn btn-raise" ${!canAct ? 'disabled' : ''}
                onclick="sendCommand('${table.table_id}', ${seat.seat_index}, 'raise_max')">
                RAISE MAX
              </button>
              <button class="action-btn btn-cashout" ${!canAct ? 'disabled' : ''}
                onclick="sendCommand('${table.table_id}', ${seat.seat_index}, 'cashout')">
                CASHOUT
              </button>
            </div>
          </div>
        `;
      }).join('');

      app.innerHTML = `
        <div class="table-container">
          <div class="table-info">
            <div class="street-display">${table.street}</div>
            <div class="pot-display">POT: ZAR ${table.pot_zar ? table.pot_zar.toFixed(2) : '0.00'}</div>
          </div>
          <div class="board-display">
            ${boardHtml}
          </div>
          <div class="seats-grid">
            ${seatsHtml}
          </div>
        </div>
      `;
    }

    // Show waiting message
    function showWaiting() {
      // Show empty 9-seat table instead of waiting message
      const emptyTable = {
        table_id: "waiting",
        variant: "plo",
        street: "WAITING",
        pot_zar: 0,
        dealer_seat: null,
        board: { flop: [], turn: null, river: null },
        seats: Array.from({ length: 9 }, (_, i) => ({
          seat_index: i + 1,
          name: null,
          stack_zar: 0,
          hole_cards: [],
          status: "empty",
          is_dealer: false,
          has_token: false,
          last_seen_ago: null,
          pending_cmd: null
        }))
      };
      renderTable(emptyTable);
    }

    // Poll for table updates
    function poll() {
      fetch(API_BASE + '/table/latest')
        .then(r => r.json())
        .then(data => {
          if (data.ok && data.table) {
            renderTable(data.table);
          } else {
            showWaiting();
          }
        })
        .catch(err => {
          console.error('Poll error:', err);
          showWaiting();
        });
    }

    // Start polling
    showWaiting();
    poll();
    setInterval(poll, 250);
  
    // Copy inject code to clipboard
    function copyInjectCode() {
      const code = document.getElementById('inject-command').textContent;
      navigator.clipboard.writeText(code).then(() => {
        const btn = document.querySelector('.copy-btn');
        btn.textContent = '✓ COPIED';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'COPY';
          btn.classList.remove('copied');
        }, 2000);
      });
    }

  </script>
</body>
</html>
